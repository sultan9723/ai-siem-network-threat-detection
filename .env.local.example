# AI SIEM Frontend - Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Backend API URL (required)
# For local development:
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Demo credentials (for development mode UX - intentionally enabled)
# Backend validates using bcrypt; plaintext passwords NOT stored on server
NEXT_PUBLIC_DEV_USERNAME=admin
NEXT_PUBLIC_DEV_PASSWORD=admin123

# For production (update with your Render backend URL):
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
