# AI SIEM Backend - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# JWT Configuration (required)
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this

# JWT algorithm (default: HS256)
ALGORITHM=HS256

# Token expiration in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin credentials (required)
ADMIN_USERNAME=admin

# Generate a bcrypt hash for your admin password:
#   python -c "from passlib.context import CryptContext; ctx = CryptContext(schemes=['bcrypt'], deprecated='auto'); print(ctx.hash('your-password'))"
# Default password is 'admin123' - change this in production:
ADMIN_PASSWORD_HASH=$2b$12$zNGJ4TtetZbCuiWH4eRs6uR2i7ZNXtdiD9CZS25sMN5oV7fDCadKW

# CORS: Allowed frontend origin
FRONTEND_URL=http://localhost:3000

# OpenRouter API key for AI threat analysis (optional)
# If not set, the system falls back to rule-based analysis
OPENROUTER_API_KEY=

# Server port (default: 8000, Render overrides with $PORT)
PORT=8000
