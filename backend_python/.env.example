# AI SIEM Backend - Environment Variables
# Copy to .env and fill in your values. Never commit this file.

# JWT signing key (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=

# Admin username
ADMIN_USERNAME=admin

# Bcrypt hash of admin password (generate: python generate_hash.py)
ADMIN_PASSWORD_HASH=

# JWT settings (defaults shown)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Optional: OpenRouter API key for AI analysis
OPENROUTER_API_KEY=

# Server port
PORT=8000
